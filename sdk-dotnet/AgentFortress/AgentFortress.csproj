<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0;net7.0;net8.0;net10.0</TargetFrameworks>
    <PackageId>AgentFortress</PackageId>
    <Version>2.0.0</Version>
    <Authors>Aayush</Authors>
    <Description>Runtime protection and security monitoring for AI agents — The CrowdStrike for AI Agents</Description>
    <PackageTags>security;ai;agents;llm;monitoring;threat-detection;prompt-injection</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/aayush022008/agentfortress</PackageProjectUrl>
    <RepositoryUrl>https://github.com/aayush022008/agentfortress</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
